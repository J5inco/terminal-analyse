{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-refresh",
      "schedule": "0 2 1,15 * *"
    },
    {
      "path": "/api/cron-collect",
      "schedule": "20,40 2-5 1,15 * *"
    }
  ]
}
